    <script id="imagenesMascotasData" type="application/json">
        <%- JSON.stringify(typeof imagenes !== "undefined" ? imagenes : []) %>
    </script>

    <script>

        // ANIMACIONES SCROLL

        const fadeElements = document.querySelectorAll('.fade-up');

        const observer = new IntersectionObserver((entries) => {

            entries.forEach(entry => {

                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }

            });

        }, {
            threshold: 0.2
        });

        fadeElements.forEach(el => observer.observe(el));



        // HEADER COMPACTO

        const header = document.querySelector('header');
        let headerScrollTicking = false;
        let headerIsScrolled = false;

        const updateHeaderState = () => {
            const shouldBeScrolled = window.scrollY > 50;

            if (shouldBeScrolled !== headerIsScrolled) {
                headerIsScrolled = shouldBeScrolled;
                header.classList.toggle('scrolled', shouldBeScrolled);
            }

            headerScrollTicking = false;
        };

        window.addEventListener('scroll', () => {
            if (!headerScrollTicking) {
                window.requestAnimationFrame(updateHeaderState);
                headerScrollTicking = true;
            }
        }, { passive: true });

        updateHeaderState();


        // CARRUCEL FOTOS MASCOTAS
        const imagenesMascotasData = document.getElementById('imagenesMascotasData');
        const imagenesMascotas = JSON.parse(imagenesMascotasData.textContent);
        const heroMascota = document.getElementById('heroMascota');

        if (heroMascota && imagenesMascotas.length > 0) {
            // Mezclar aleatoriamente
            imagenesMascotas.sort(() => Math.random() - 0.5);

            let indiceMascota = 0;
            heroMascota.src = imagenesMascotas[0];

            setInterval(() => {

                heroMascota.style.opacity = '0';

                setTimeout(() => {

                    indiceMascota = (indiceMascota + 1) % imagenesMascotas.length;
                    heroMascota.src = imagenesMascotas[indiceMascota];

                    heroMascota.animate(
                        [
                            { transform: 'scale(1.1)' },
                            { transform: 'scale(1)' }
                        ],
                        {
                            duration: 1000,
                            easing: 'ease-out'
                        }
                    );

                    heroMascota.style.opacity = '1';

                }, 400);

            }, 4000);
        }

    </script>

</body>

</html>
