    <!-- HERO -->

<br>
        



            <div class="contenedor-iframe" id="iframeWrapper">
                <iframe
                    id="miIframe"
                    src="https://fielpet.com/v/Ppiotrowsky"
                    scrolling="no">
                </iframe>
            </div>
          
          <script>
            const iframe = document.getElementById("miIframe");
            const iframeWrapper = document.getElementById("iframeWrapper");
          
            let cargas = 0;
          
            iframe.addEventListener("load", function () {
              cargas++;
          
              // Primera carga: página inicial
              // Segunda carga: posible redirección dentro del iframe
              if (cargas >= 2) {
                iframeWrapper.style.height = "900px";
                iframe.setAttribute("scrolling", "yes");
                iframe.style.overflow = "auto";
              }
            });
          </script>





    <!-- FOOTER -->

    <footer>

        <div class="container">

            <p>
                © 2026 Seguros Piotrowsky - Todos los derechos reservados.
            </p>

        </div>

    </footer>

    <!-- BOTON WHATSAPP -->
