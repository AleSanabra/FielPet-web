    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #00b67a;
            --primary-dark: #009966;
            --secondary: #f5f7f9;
            --text: #1f2937;
            --gray: #6b7280;
            --white: #ffffff;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--white);
            color: var(--text);
            overflow-x: hidden;
        }

        html {
            scroll-behavior: smooth;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: auto;
        }

        /* HEADER */

        header {
            padding: 18px 0;
            background: #00b67a;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
        }

        .header-content {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 90px;
            transition: all 0.3s ease;
        }

        /* LOGO FIELPET */

        .header-title {
            text-align: center;
            color: white;
            transition: all 0.3s ease;
        }

        .header-title img {
            height: 95px;
            object-fit: contain;
            transition: all 0.3s ease;
        }

        .header-title span {
            display: block;
            margin-top: 5px;
            font-size: 1rem;
            font-weight: 500;
            color: white;
            transition: all 0.3s ease;
        }

        /* LOGO PIOTROWSKY */

        .header-logo {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            transition: all 0.3s ease;
        }

        .header-logo img {
            height: 55px;
            object-fit: contain;
            transition: all 0.3s ease;
        }

        .header-logo img:hover {
            transform: scale(1.05);
        }

        /* HEADER COMPACTO AL HACER SCROLL */

        header.scrolled {
            padding: 8px 0;
        }

        header.scrolled .header-content {
            min-height: 55px;
        }

        header.scrolled .header-title img {
            height: 55px;
        }

        header.scrolled .header-title span {
            display: none;
        }

        /* ESCONDER LOGO SEGURO EN SCROLL MOBILE */

        @media(max-width: 768px) {

            header.scrolled .header-logo {
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
            }

        }

        /* RESPONSIVE */

        @media(max-width: 768px) {

            header {
                padding: 15px 0;
            }

            .header-title img {
                height: 75px;
            }

            .header-logo img {
                height: 45px;
            }

        }

        /* HERO */

        .hero {
            padding: 90px 0;
            background: linear-gradient(to bottom right, #f8fffc, #eefdf6);
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .hero-text h2 {
            font-size: 3.5rem;
            line-height: 1.1;
            margin-bottom: 25px;
        }

        .hero-text h2 span {
            color: var(--primary);
        }

        .hero-text p {
            font-size: 1.15rem;
            color: var(--gray);
            line-height: 1.7;
            margin-bottom: 35px;
        }

        .hero-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            text-decoration: none;
            padding: 16px 28px;
            border-radius: 14px;
            font-weight: 600;
            transition: 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: white;
            color: var(--text);
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background: #f9f9f9;
            transform: translateY(-2px);
        }

        .hero-image {
            position: relative;
            animation: float 4s ease-in-out infinite;
        }

        .hero-image img {
            width: 100%;
            border-radius: 30px;
            box-shadow: var(--shadow);
            transition: opacity 0.8s ease;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        /* BENEFITS */

        .benefits {
            padding: 90px 0;
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-size: 2.5rem;
            margin-bottom: 15px;
        }

        .section-title p {
            color: var(--gray);
            font-size: 1.05rem;
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
        }

        .benefit-card {
            background: white;
            border-radius: 24px;
            padding: 35px;
            box-shadow: var(--shadow);
            transition: 0.3s ease;
        }

        .benefit-card:hover {
            transform: translateY(-6px);
        }

        .benefit-icon {
            width: 65px;
            height: 65px;
            background: rgba(0, 182, 122, 0.12);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 25px;
        }

        .benefit-card h3 {
            margin-bottom: 15px;
            font-size: 1.3rem;
        }

        .benefit-card p {
            color: var(--gray);
            line-height: 1.7;
        }

        /* CTA */

        .cta {
            padding: 90px 0;
            background: linear-gradient(to right, #00b67a, #00d18d);
            color: white;
            text-align: center;
        }

        .cta h2 {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .cta p {
            max-width: 700px;
            margin: auto;
            margin-bottom: 35px;
            line-height: 1.8;
            font-size: 1.1rem;
        }

        .cta .btn-primary {
            background: white;
            color: var(--primary);
        }

        .cta .btn-primary:hover {
            background: #f3f3f3;
        }

        /* SUCURSALES */

        .branches {
            padding: 90px 0;
            background: var(--secondary);
        }

        .branches-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }

        .branch-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: 0.3s ease;

        }

        .branch-card:hover {
            transform: translateY(-5px);
        }

        .branch-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .branch-content {
            padding: 30px;
        }

        .branch-content h3 {
            margin-bottom: 15px;
            font-size: 1.5rem;
        }

        .branch-content p {
            color: var(--gray);
            margin-bottom: 10px;
            line-height: 1.6;
        }

        .branch-card a {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        /* FOOTER */

        footer {
            padding: 40px 0;
            text-align: center;
            background: white;
            border-top: 1px solid #eee;
        }

        footer p {
            color: var(--gray);
        }

        /* WHATSAPP */

        .whatsapp {
            position: fixed;
            right: 25px;
            bottom: 25px;
            width: 70px;
            height: 70px;
            background: #25D366;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            text-decoration: none;
            font-size: 2rem;
            color: white;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            z-index: 999;
            transition: 0.3s ease;
        }

        .whatsapp:hover {
            transform: scale(1.08);
        }

        /* RESPONSIVE */

        @media(max-width: 992px) {

            .hero-grid,
            .benefits-grid,
            .branches-grid {
                grid-template-columns: 1fr;
            }

            .hero {
                text-align: center;
            }

            .hero-buttons {
                justify-content: center;
            }

            .hero-text h2 {
                font-size: 2.7rem;
            }

            .cta h2 {
                font-size: 2.2rem;
            }
        }

        /* RESPONSIVE MOBILE */

        @media(max-width: 768px) {

            header {
                padding: 10px 0;
            }

            .header-content {
                position: relative;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 8px;
                min-height: auto;
            }

            /* FIELPET */

            .header-title {
                text-align: center;
            }

            .header-title img {
                height: 60px;
            }

            .header-title span {
                font-size: 0.85rem;
            }

            /* LOGO PIOTROWSKY */

            .header-logo {
                position: relative;
                right: auto;
                top: auto;
                transform: none;
            }

            .header-logo img {
                height: 32px;
            }

            /* HEADER COMPACTO */

            header.scrolled {
                padding: 6px 0;
            }

            header.scrolled .header-content {
                gap: 0;
            }

            header.scrolled .header-title img {
                height: 45px;
            }

            header.scrolled .header-title span {
                display: none;
            }

            /* OCULTAR LOGO SEGURO */

            header.scrolled .header-logo {
                display: none;
            }

        }

        @media(max-width: 576px) {

            .hero-text h2 {
                font-size: 2.2rem;
            }

            .section-title h2 {
                font-size: 2rem;
            }

            .cta h2 {
                font-size: 1.9rem;
            }

            .btn {
                width: 100%;
            }

            .hero-buttons {
                flex-direction: column;
            }
        }

        /* ANIMACIONES */

        .fade-up {
            opacity: 0;
            transform: translateY(40px);
            transition: all 1s ease;
        }

        .fade-up.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Iframe cotizador */
        :root {
            --iframe-header-crop: 120px;
            --iframe-footer-crop: 120px;
        }

        .contenedor-iframe {
            width: 100%;
            height: 400px;
            overflow: hidden;
            position: relative;
        }

        .contenedor-iframe iframe {
            width: 100%;
            height: calc(100% + var(--iframe-header-crop) + var(--iframe-footer-crop));
            border: none;
            display: block;
            overflow: hidden;
            position: relative;
            top: calc(-1 * var(--iframe-header-crop));
        }



    </style>

</head>

<body>

